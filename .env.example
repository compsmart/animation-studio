# KIE.ai API Key (get from https://kie.ai/)
KIE_API_KEY=your_key_here

# Google Gemini API Key (for Spine idle analysis - optional)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Server port
PORT=3001

# Public URL where this server is accessible (used so Kling can fetch reference images)
# For local dev, use ngrok or similar: https://your-ngrok-url.ngrok.io
# If not set, defaults to http://localhost:PORT (won't work with Kling image input)
PUBLIC_URL=http://localhost:3001
